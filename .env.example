# .env.example
# Lemma SDK Configuration
LEMMA_API_URL=https://your-lemma-api-url.lemma.work
LEMMA_AUTH_URL=https://your-lemma-auth-url.lemma.work
LEMMA_POD_ID=your-pod-id-here

# Optional: For GitHub Post-Mortem Integration
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repo_name

# Optional: OpenAI API Key for embeddings (if using OpenAI embeddings)
OPENAI_API_KEY=your_openai_api_key_here